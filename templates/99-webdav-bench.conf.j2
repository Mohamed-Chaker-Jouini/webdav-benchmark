# Managed by Ansible - webdav-benchmark tuning

# Backlog / connection setup - fixes curl_rc=7 connection-refused under parallel bursts
net.core.somaxconn = 65535
net.ipv4.tcp_max_syn_backlog = 65535

# Port range + fast TIME_WAIT reuse - fixes port exhaustion on repeated parallel runs
net.ipv4.ip_local_port_range = 1024 65535
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15

# Socket buffers sized for multi-Gbit throughput over the 192.168.95.0/24 link
net.core.rmem_max = 67108864
net.core.wmem_max = 67108864
net.ipv4.tcp_rmem = 4096 87380 67108864
net.ipv4.tcp_wmem = 4096 65536 67108864
net.core.netdev_max_backlog = 65535

net.ipv4.tcp_slow_start_after_idle = 0
net.ipv4.tcp_mtu_probing = 1

# File descriptors
fs.file-max = 2097152
