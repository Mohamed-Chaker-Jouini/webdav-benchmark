server {
    listen 8080 default_server;
    server_name _;

    client_max_body_size 0;

    # Keep per-connection RAM buffer small; spill straight to disk instead of RAM
    client_body_buffer_size 16M;
    client_body_temp_path /data/webdav_tmp 1 2;

    # Bypass the page cache for large file I/O (this is what actually prevents
    # OOM under load - without it, every up/download fills page cache RAM
    # until the kernel starts reclaiming aggressively / OOM-killing nginx)
    aio threads;
    directio 4m;
    directio_alignment 4k;
    output_buffers 2 1m;

    sendfile off;      # incompatible with directio, not needed for dav PUT/GET anyway
    tcp_nopush on;
    tcp_nodelay on;

    keepalive_timeout 65s;
    keepalive_requests 100000;
    reset_timedout_connection on;

    location /dav {
        alias /data/webdav;

        dav_methods PUT DELETE MKCOL COPY MOVE;
        create_full_put_path on;
        dav_access user:rw group:rw all:rw;

        autoindex on;
    }
}