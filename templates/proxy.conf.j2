server {
    listen 8080 default_server;
    server_name _;

    client_max_body_size 0;

    location / {
        # Forward traffic to WebDAV backend VM
        proxy_pass http://{{ hostvars[groups['webdav_backend'][0]]['inventory_hostname'] }}:8080;

        # Direct streaming: No proxy disk buffering for uploads or downloads
        proxy_request_buffering off;
        proxy_buffering off;
        proxy_max_temp_file_size 0;

        # HTTP/1.1 Persistent connection pool
        proxy_http_version 1.1;
        proxy_set_header Connection "";

        # Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}